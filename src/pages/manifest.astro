---
import BaseLayout from '../layouts/BaseLayout.astro';

const dna = [
  'Pełna autonomia',
  'Synergia społeczności',
  'Niezależna przedsiębiorczość',
  'Rozwój technologii',
  'Równość oparta o demokrację bezpośrednią',
  'Dobrowolność i odpowiedzialność',
];
const wierzymy = [
  { t: 'Wolność i zaufanie', o: 'jako podstawa relacji.' },
  { t: 'Równość i koleżeństwo', o: 'bo każdy głos jest tak samo ważny.' },
  { t: 'Transparentność', o: 'w każdym działaniu.' },
  { t: 'Honor i odwaga', o: 'by podejmować wyzwania i stać na straży wartości.' },
];
const strategia = [
  { krok: '01', tytul: 'Inicjatywa', opis: 'Każdy pomysł jest mile widziany, bo to on nas napędza.' },
  { krok: '02', tytul: 'Demokracja bezpośrednia', opis: 'Wspólnie podejmujemy decyzje i wspólnie za nie odpowiadamy.' },
  { krok: '03', tytul: 'Wzajemne wsparcie', opis: 'Tworzymy społeczność, w której się wspieramy.' },
];
---
<BaseLayout
  title="Manifest — Lobby Obywatelskie"
  description="Manifest Lobby Obywatelskie — neutralny politycznie, oddolny ruch społeczny na rzecz dobra wspólnego."
>
  <header class="page-hero container">
    <p class="eyebrow">Manifest</p>
    <h1>Razem decydujeMy,<br />razem tworzyMy.</h1>
    <p class="lede">
      Ruch społeczny działający na rzecz dobra wspólnego. Mamy dość pustych słów
      i czekania, aż ktoś za nas zmieni świat. Bierzemy sprawy w swoje ręce — bo
      zmiana zaczyna się od nas. To nie deklaracja. To zobowiązanie.
    </p>
  </header>

  <section class="container">
    <p class="eyebrow">Kim jesteśmy — nasze DNA</p>
    <p class="intro">Jesteśmy neutralni politycznie i działamy oddolnie. Nie interesują nas
    partyjne spory, lecz skuteczność w działaniu. Naszą siłą jest:</p>
    <ul class="tick-list grid-2">
      {dna.map((d) => <li><span class="tick">✕</span> {d}</li>)}
    </ul>
  </section>

  <section class="container">
    <p class="eyebrow">Wierzymy w</p>
    <dl class="beliefs">
      {wierzymy.map((w) => (
        <div>
          <dt>{w.t}</dt>
          <dd>{w.o}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="container">
    <p class="eyebrow">Jak działamy — nasza strategia</p>
    <ol class="proc">
      {strategia.map((p) => (
        <li>
          <span class="proc-num">{p.krok}</span>
          <div>
            <h3>{p.tytul}</h3>
            <p>{p.opis}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="container goal">
    <p class="eyebrow">Dokąd zmierzamy</p>
    <h2>Tworzymy zaangażowaną wspólnotę mającą wpływ na rozwój gospodarczy.</h2>
    <p class="intro">Wnieś swoje pasje, pomysły i energię. Zamiast szukać tego, co nas
    dzieli, znajdź to, co nas łączy. Razem dokonamy zmian.</p>
    <a class="btn" href="/kontakt">Dołącz do nas</a>
  </section>

  <style>
    .page-hero { padding: clamp(2.5rem, 6vw, 4rem) 1.5rem; border-bottom: 1px solid var(--line); }
    .page-hero h1 { font-size: var(--step-3); margin: 0 0 1rem; }
    .page-hero .lede, .intro { max-width: 42rem; color: #34373d; }
    .page-hero .lede { font-size: var(--step-1); margin: 0; }
    .intro { margin: 0 0 1.5rem; }

    .tick-list { list-style: none; padding: 0; margin: 0; }
    .tick-list li { display: flex; gap: 0.9rem; align-items: flex-start; padding: 0.7rem 0; border-bottom: 1px dashed var(--line); }
    .tick-list .tick { font-size: 0.8em; margin-top: 0.15em; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; column-gap: 2.5rem; }

    .beliefs { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 0; }
    .beliefs dt { font-family: var(--f-display); font-weight: 800; font-size: var(--step-1); color: var(--ink); }
    .beliefs dd { margin: 0.25rem 0 0; color: #34373d; }

    .proc { list-style: none; padding: 0; margin: 0; }
    .proc li { display: flex; gap: 1.25rem; align-items: baseline; padding: 1.25rem 0; border-top: 1px solid var(--ink); }
    .proc-num { font-family: var(--f-mono); font-weight: 500; color: var(--red); font-size: var(--step-1); flex: 0 0 auto; }
    .proc h3 { font-size: var(--step-1); margin: 0 0 0.25rem; }
    .proc p { margin: 0; color: #34373d; }

    .goal h2 { font-size: var(--step-2); max-width: 38rem; margin: 0 0 1rem; }

    @media (max-width: 640px) {
      .grid-2, .beliefs { grid-template-columns: 1fr; }
      .beliefs { gap: 1.25rem; }
    }
  </style>
</BaseLayout>
