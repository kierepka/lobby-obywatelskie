---
import BaseLayout from '../layouts/BaseLayout.astro';
const emaile = [
  { adres: 'kontakt@lobbyobywatelskie.pl', opis: 'Sprawy ogólne i pierwszy kontakt — gdy nie wiesz, gdzie napisać.' },
  { adres: 'wspolpraca@lobbyobywatelskie.pl', opis: 'Wspólne projekty, partnerstwa i propozycje współdziałania.' },
  { adres: 'media@lobbyobywatelskie.pl', opis: 'Dziennikarze, wywiady i zapytania prasowe.' },
  { adres: 'zgloszenia@lobbyobywatelskie.pl', opis: 'Zgłoś pomysł, inicjatywę lub sprawę do wspólnej decyzji.' },
  { adres: 'administracja@lobbyobywatelskie.pl', opis: 'Sprawy organizacyjne, członkostwo i kwestie formalne.' },
  { adres: 'pytania@lobbyobywatelskie.pl', opis: 'Pytania o to, kim jesteśmy i jak działamy.' },
];
---
<BaseLayout title="Kontakt — Lobby Obywatelskie">
  <header class="page-hero container">
    <p class="eyebrow">Kontakt</p>
    <h1>Dołącz do nas.</h1>
    <p class="lede">Spotykamy się w każdą środę o 22:00. Napisz — odpowiadamy.</p>
    <div class="hero-actions">
      <a class="btn" href="https://rozmowy.wikikracja.pl/otwarte" target="_blank" rel="noopener noreferrer">Dołącz do spotkania</a>
      <a class="btn btn--ghost" href="mailto:kontakt@lobbyobywatelskie.pl?subject=Chc%C4%99%20do%C5%82%C4%85czy%C4%87">Napisz do nas</a>
    </div>
  </header>

  <section class="container">
    <p class="eyebrow">Adresy</p>
    <ul class="emaile">
      {emaile.map((e) => (
        <li>
          <a href={`mailto:${e.adres}`}>{e.adres}</a>
          <span class="opis">{e.opis}</span>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .page-hero { padding: clamp(2.5rem, 6vw, 4rem) 1.5rem; border-bottom: 1px solid var(--line); margin-bottom: 0; }
    .page-hero h1 { font-size: var(--step-3); margin: 0 0 1rem; }
    .page-hero .lede { font-size: var(--step-1); max-width: 34rem; color: #34373d; margin: 0 0 1.75rem; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: .85rem; }

    .emaile { list-style: none; padding: 0; margin: 0; }
    .emaile li {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem 1.5rem;
      padding: 1rem 0;
      border-bottom: 1px solid var(--line);
    }
    .emaile a { font-family: var(--f-mono); font-size: 1rem; }
    .opis { color: var(--muted); font-size: var(--step--1); }
  </style>
</BaseLayout>
