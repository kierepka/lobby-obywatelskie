---
import { url } from '../lib/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('aktualnosci', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const steps = [
  {
    number: '01',
    title: 'Proponujesz',
    text: 'Każdy może wnieść pomysł. Trzy podpisy wystarczą, by rozpocząć obywatelską inicjatywę.',
    icon: '✦',
  },
  {
    number: '02',
    title: 'Dyskutujemy',
    text: 'Otwarta, rzeczowa debata daje przestrzeń na argumenty, zanim zapadnie wspólna decyzja.',
    icon: '◎',
  },
  {
    number: '03',
    title: 'Decydujesz',
    text: 'Tajne referendum i prosta zasada: jedna osoba to jeden, równie ważny głos.',
    icon: '✓',
  },
];

const historyRecords = [
  {
    date: 'ok. 550',
    kind: 'Zapis źródłowy',
    title: 'Prokopiusz o decyzjach wczesnych Słowian',
    text: 'W „Wojnach” opisał Sklawinów i Antów jako społeczności bez jednego władcy, odnoszące ważne sprawy do ogółu.',
    caveat: 'Świadectwo dotyczy grup znad dolnego Dunaju, nie bezpośrednio mieszkańców ziem polskich.',
    source: 'https://doi.org/10.1017/CBO9780511496295.008',
    sourceLabel: 'Cambridge University Press',
  },
  {
    date: '1180',
    kind: 'Udokumentowany zjazd',
    title: 'Zjazd w Łęczycy',
    text: 'Kazimierz II Sprawiedliwy spotkał się z dostojnikami duchownymi i świeckimi. Zjazd przyjął postanowienia ograniczające część ciężarów prawa książęcego.',
    caveat: 'Było to zgromadzenie elit, a nie powszechne głosowanie ludności.',
    source: 'https://bazhum.muzhp.pl/media/texts/collectanea-theologica/1936-tom-17-numer-1-2/collectanea_theologica-r1936-t17-n1_2-s183-206.pdf',
    sourceLabel: 'Opracowanie źródłowe',
  },
  {
    date: '1505',
    kind: 'Prawo stanowione',
    title: 'Konstytucja Nihil novi',
    text: 'Sejm w Radomiu utrwalił zasadę, że nowych praw nie ustanawia się bez zgody reprezentacji sejmowej.',
    caveat: 'Był to system przedstawicielski ograniczony do stanu szlacheckiego, nie demokracja bezpośrednia.',
    source: 'https://biblioteka.sejm.gov.pl/wp-content/uploads/2019/04/folder-PL.pdf',
    sourceLabel: 'Biblioteka Sejmowa',
  },
  {
    date: '1997',
    kind: 'Referendum ogólnokrajowe',
    title: 'Obywatele zatwierdzają Konstytucję RP',
    text: '25 maja w głosowaniu ogólnokrajowym przyjęto Konstytucję uchwaloną wcześniej przez Zgromadzenie Narodowe.',
    caveat: 'To rzeczywisty przykład bezpośredniego rozstrzygnięcia ustrojowego przez obywateli.',
    source: 'https://isap.sejm.gov.pl/isap.nsf/DocDetails.xsp?id=WDU19970750476',
    sourceLabel: 'Obwieszczenie PKW',
  },
  {
    date: '2003',
    kind: 'Wiążące referendum',
    title: 'Decyzja o wejściu Polski do Unii Europejskiej',
    text: '7–8 czerwca obywatele bezpośrednio zdecydowali o zgodzie na ratyfikację traktatu akcesyjnego.',
    caveat: 'Wynik przekroczył wymagany próg frekwencji i był wiążący.',
    source: 'https://referendum2003.pkw.gov.pl/informacje_prasowe/Obwieszczenie_o_wyniku_referendum_akcesyjnego.htm',
    sourceLabel: 'Państwowa Komisja Wyborcza',
  },
];
---
<BaseLayout title="Lobby Obywatelskie — Razem możemy więcej">
  <Hero />

  <section class="container intro-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Prosty mechanizm</p>
        <h2>Demokracja, która naprawdę działa.</h2>
      </div>
      <p>
        Dajemy społeczności jasny proces przechodzenia od pomysłu do wspólnej,
        wiążącej decyzji.
      </p>
    </div>
    <div class="how">
      {steps.map((step) => (
        <article class="how-item">
          <div class="how-top">
            <span class="how-icon">{step.icon}</span>
            <span class="how-number">{step.number}</span>
          </div>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="manifest-band">
    <div class="container manifest-grid">
      <div class="manifest-mark" aria-hidden="true">
        <span>1</span>
        <div><b>OSOBA</b><i></i><b>GŁOS</b></div>
        <span>1</span>
      </div>
      <div class="manifest-copy">
        <p class="eyebrow">Nasze zobowiązanie</p>
        <h2>Nie czekamy, aż ktoś zmieni świat za nas.</h2>
        <p>
          Jesteśmy neutralnym politycznie, oddolnym ruchem społecznym.
          Łączą nas wolność, odpowiedzialność i przekonanie, że sprawy wspólne
          powinny być rozstrzygane wspólnie.
        </p>
        <a class="text-link" href={url('/manifest')}>Przeczytaj manifest <span>→</span></a>
      </div>
    </div>
  </section>

  <section class="container news-section">
    <div class="news-head">
      <div>
        <p class="eyebrow">Aktualności</p>
        <h2>Jesteśmy w ruchu.</h2>
      </div>
      <a class="news-all" href={url('/aktualnosci')}>Wszystkie aktualności <span>→</span></a>
    </div>
    <div class="news-grid">
      {posts.map((p) => (
        <NewsCard title={p.data.title} date={p.data.date} description={p.data.description} href={url(`/aktualnosci/${p.slug}`)} />
      ))}
    </div>
  </section>

  <section class="records-section">
    <div class="container">
      <div class="records-head">
        <div>
          <p class="eyebrow">Historyczne zapisy</p>
          <h2>Współdecydowanie — fakty, nie legenda.</h2>
        </div>
        <p>
          Źródła pokazują różne formy udziału we wspólnych decyzjach.
          Nie były one jednak tym samym: od narady plemiennej, przez zgromadzenia
          elit i parlament, aż po współczesne referendum powszechne.
        </p>
      </div>

      <div class="records-list">
        {historyRecords.map((record, index) => (
          <article class="record">
            <div class="record-date">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <strong>{record.date}</strong>
            </div>
            <div class="record-main">
              <p class="record-kind">{record.kind}</p>
              <h3>{record.title}</h3>
              <p>{record.text}</p>
            </div>
            <div class="record-proof">
              <p><span aria-hidden="true">i</span>{record.caveat}</p>
              <a href={record.source} target="_blank" rel="noopener noreferrer">
                {record.sourceLabel} <span aria-hidden="true">↗</span>
              </a>
            </div>
          </article>
        ))}
      </div>

      <aside class="records-note">
        <strong>Co z tego wynika?</strong>
        <p>
          Nie ma dowodu na prostą ciągłość od słowiańskiego wiecu do dzisiejszego
          referendum. Jest za to dobrze udokumentowana, powracająca w polskiej
          historii zasada, że władza powinna pytać o zgodę tych, których dotyczy decyzja.
        </p>
      </aside>
    </div>
  </section>

  <section class="container join">
    <div>
      <p class="eyebrow">Spotkajmy się</p>
      <h2>Masz pomysł? Zacznijmy od rozmowy.</h2>
      <p>Spotykamy się online w każdą środę o 21:00.</p>
    </div>
    <a class="btn" href={url('/kontakt')}>Napisz do nas</a>
  </section>

  <style>
    .section-heading {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(18rem, .8fr);
      gap: 3rem;
      align-items: end;
      margin-bottom: 2.5rem;
    }
    .section-heading h2, .news-head h2, .manifest-copy h2, .join h2 {
      font-size: var(--step-3);
      margin: 0;
    }
    .section-heading > p { max-width: 31rem; margin: 0; color: var(--muted); }
    .how {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-auto-rows: 1fr;
      gap: 1.1rem;
      align-items: stretch;
    }
    .how-item {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 1.6rem;
      border: 1px solid var(--line);
      border-radius: .9rem;
      background: rgba(255,255,255,.75);
      box-shadow: 0 10px 35px rgba(13,33,59,.045);
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .how-item:hover { transform: translateY(-5px); border-color: #c7d5e3; box-shadow: var(--shadow-sm); }
    .how-top { display: flex; align-items: center; justify-content: space-between; }
    .how-icon {
      display: grid;
      place-items: center;
      width: 3.25rem;
      height: 3.25rem;
      border-radius: .8rem;
      background: var(--blue-light);
      color: var(--blue);
      font: 700 1.3rem var(--f-display);
    }
    .how-item:nth-child(2) .how-icon { background: #fce8ec; color: var(--red); }
    .how-number { font: 700 1.7rem var(--f-display); color: #dde5ec; }
    .how-item h3 { font-size: var(--step-2); margin: 3rem 0 .8rem; }
    .how-item p { margin: 0; color: var(--muted); }

    .records-section {
      padding: clamp(4.5rem, 9vw, 8rem) 0;
      background:
        linear-gradient(90deg, rgba(21,59,104,.035) 1px, transparent 1px),
        linear-gradient(rgba(21,59,104,.035) 1px, transparent 1px),
        #fff;
      background-size: 34px 34px;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .records-head {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(18rem, .9fr);
      gap: 3rem;
      align-items: end;
      margin-bottom: 3rem;
    }
    .records-head h2 { max-width: 15ch; margin: 0; font-size: var(--step-3); }
    .records-head > p { max-width: 36rem; margin: 0; color: var(--muted); }
    .records-list {
      border-top: 2px solid var(--ink);
    }
    .record {
      display: grid;
      grid-template-columns: 7rem minmax(0, 1.15fr) minmax(15rem, .85fr);
      gap: clamp(1.25rem, 4vw, 3rem);
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--line);
      align-items: start;
    }
    .record-date { display: grid; gap: .35rem; }
    .record-date span {
      color: var(--red);
      font: 700 .62rem var(--f-display);
      letter-spacing: .1em;
    }
    .record-date strong {
      font: 700 1.1rem var(--f-display);
      color: var(--blue);
    }
    .record-kind {
      margin: 0 0 .35rem !important;
      color: var(--red) !important;
      font: 700 .65rem var(--f-display);
      letter-spacing: .09em;
      text-transform: uppercase;
    }
    .record-main h3 { margin: 0 0 .5rem; font-size: 1.15rem; letter-spacing: -.015em; }
    .record-main > p:last-child { margin: 0; color: #465667; font-size: .92rem; }
    .record-proof { display: grid; gap: .8rem; }
    .record-proof p {
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      gap: .55rem;
      margin: 0;
      color: var(--muted);
      font-size: .76rem;
      line-height: 1.5;
    }
    .record-proof p > span {
      display: grid;
      place-items: center;
      width: 1.35rem;
      height: 1.35rem;
      border-radius: 50%;
      background: var(--blue-light);
      color: var(--blue);
      font: 700 .6rem var(--f-display);
    }
    .record-proof a {
      font: 700 .65rem var(--f-display);
      letter-spacing: .04em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .record-proof a span { color: var(--red); }
    .records-note {
      display: grid;
      grid-template-columns: 12rem 1fr;
      gap: 1.5rem;
      margin-top: 2rem;
      padding: 1.3rem 1.5rem;
      border: 1px solid #b9c8d5;
      border-left: 4px solid var(--red);
      border-radius: .6rem;
      background: #fff;
    }
    .records-note strong { font: 700 .85rem var(--f-display); }
    .records-note p { max-width: 48rem; margin: 0; color: var(--muted); font-size: .86rem; }

    .manifest-band {
      padding: clamp(4rem, 8vw, 7rem) 0;
      background: var(--blue);
      color: #fff;
      overflow: hidden;
    }
    .manifest-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(3rem, 8vw, 7rem); align-items: center; }
    .manifest-mark {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      min-height: 18rem;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,.09), transparent 65%);
      font: 700 clamp(4rem, 10vw, 8rem)/1 var(--f-display);
    }
    .manifest-mark > span:last-child { color: var(--red); }
    .manifest-mark div { display: grid; justify-items: center; gap: .6rem; font-size: .68rem; letter-spacing: .14em; }
    .manifest-mark i { width: 2.8rem; height: 3px; background: var(--red); transform: rotate(-12deg); }
    .manifest-copy .eyebrow { color: #fff; }
    .manifest-copy .eyebrow::before { background: var(--red); }
    .manifest-copy h2 { color: #fff; max-width: 13ch; }
    .manifest-copy > p:not(.eyebrow) { max-width: 35rem; color: #d9e3ed; margin: 1.3rem 0 1.8rem; }
    .text-link, .news-all {
      display: inline-flex;
      align-items: center;
      gap: .65rem;
      font: 700 .82rem var(--f-display);
      letter-spacing: .04em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .text-link { color: #fff; }
    .text-link span, .news-all span { color: var(--red); font-size: 1.2rem; transition: transform .18s ease; }
    .text-link:hover span, .news-all:hover span { transform: translateX(4px); }

    .news-head { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-bottom: 2.5rem; }
    .news-all { padding-bottom: .35rem; color: var(--blue); }
    .news-grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); }

    .join {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .join h2 { max-width: 16ch; font-size: var(--step-2); }
    .join p:last-child { margin: .75rem 0 0; color: var(--muted); }

    @media (max-width: 760px) {
      .section-heading, .records-head, .manifest-grid { grid-template-columns: 1fr; }
      .section-heading { gap: 1.25rem; }
      .how { grid-template-columns: 1fr; }
      .how-item h3 { margin-top: 2rem; }
      .records-head { gap: 1.25rem; }
      .record { grid-template-columns: 5rem 1fr; }
      .record-proof { grid-column: 2; }
      .records-note { grid-template-columns: 1fr; gap: .5rem; }
      .manifest-mark { min-height: 14rem; max-width: 24rem; width: 100%; justify-self: center; }
      .news-head, .join { align-items: flex-start; flex-direction: column; }
    }
    @media (max-width: 480px) {
      .record { grid-template-columns: 1fr; gap: .8rem; }
      .record-date { display: flex; align-items: baseline; justify-content: space-between; }
      .record-proof { grid-column: auto; }
    }
  </style>
</BaseLayout>
