---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('aktualnosci', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<BaseLayout title="Lobby Obywatelskie — Razem możemy więcej">
  <Hero />

  <section class="container">
    <p class="eyebrow">Jak to działa</p>
    <div class="how">
      <div class="how-item">
        <span class="tick">✕</span>
        <h3>Proponujesz</h3>
        <p>Trzy podpisy wystarczą, by rozpocząć obywatelską inicjatywę.</p>
      </div>
      <div class="how-item">
        <span class="tick">✕</span>
        <h3>Dyskutujemy</h3>
        <p>Otwarta debata, zanim cokolwiek trafi pod głosowanie.</p>
      </div>
      <div class="how-item">
        <span class="tick">✕</span>
        <h3>Decydujesz</h3>
        <p>Tajne referendum. Jedna osoba — jeden równy głos.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="news-head">
      <p class="eyebrow">Aktualności</p>
      <a class="news-all" href="/aktualnosci">Wszystkie →</a>
    </div>
    <div class="news-grid">
      {posts.map((p) => (
        <NewsCard title={p.data.title} date={p.data.date} description={p.data.description} href={`/aktualnosci/${p.slug}`} />
      ))}
    </div>
  </section>

  <style>
    .how { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .how-item { border-top: 2px solid var(--ink); padding-top: 1.1rem; }
    .how-item h3 { font-size: var(--step-1); margin: 0.9rem 0 0.4rem; }
    .how-item p { margin: 0; color: #34373d; }
    .news-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
    .news-all { font-family: var(--f-mono); font-size: var(--step--1); letter-spacing: 0.08em; text-transform: uppercase; }
    .news-grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); }
    @media (max-width: 700px) { .how { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
