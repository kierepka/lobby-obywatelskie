---
import { url } from '../lib/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('aktualnosci', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const steps = [
  {
    number: '01',
    title: 'Proponujesz',
    text: 'Każdy może wnieść pomysł. Trzy podpisy wystarczą, by rozpocząć obywatelską inicjatywę.',
    icon: '✦',
  },
  {
    number: '02',
    title: 'Dyskutujemy',
    text: 'Otwarta, rzeczowa debata daje przestrzeń na argumenty, zanim zapadnie wspólna decyzja.',
    icon: '◎',
  },
  {
    number: '03',
    title: 'Decydujesz',
    text: 'Tajne referendum i prosta zasada: jedna osoba to jeden, równie ważny głos.',
    icon: '✓',
  },
];

---
<BaseLayout title="Lobby Obywatelskie — Razem możemy więcej">
  <Hero />

  <section class="container intro-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Prosty mechanizm</p>
        <h2>Demokracja, która naprawdę działa.</h2>
      </div>
      <p>
        Dajemy społeczności jasny proces przechodzenia od pomysłu do wspólnej,
        wiążącej decyzji.
      </p>
    </div>
    <div class="how">
      {steps.map((step) => (
        <article class="how-item">
          <div class="how-top">
            <span class="how-icon">{step.icon}</span>
            <span class="how-number">{step.number}</span>
          </div>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="economy-section">
    <div class="container economy-grid">
      <div class="economy-copy">
        <p class="eyebrow">Wspólnota, która tworzy wartość</p>
        <h2>Budujemy kapitał pracą własnych rąk i siłą naszych pomysłów.</h2>
        <p>
          Demokracja nie kończy się na głosowaniu. Tworzymy wspólne inicjatywy
          gospodarcze, w których członkowie łączą umiejętności, czas i zasoby,
          aby rozwijać przedsięwzięcia budujące niezależność oraz dobrobyt grupy.
        </p>
        <a class="economy-link" href={url('/kontakt')}>
          Dołącz do nas <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="economy-panel">
        <div class="economy-panel-head">
          <span>Model wspólnego działania</span>
          <strong>Kapitał społeczny</strong>
        </div>
        <div class="value-flow">
          <article>
            <span class="value-icon">01</span>
            <div>
              <h3>Pomysły</h3>
              <p>Wnosimy wiedzę, doświadczenie i inicjatywę.</p>
            </div>
          </article>
          <i aria-hidden="true">→</i>
          <article>
            <span class="value-icon">02</span>
            <div>
              <h3>Wspólna praca</h3>
              <p>Realizujemy wybrane projekty bez biernego czekania.</p>
            </div>
          </article>
          <i aria-hidden="true">→</i>
          <article>
            <span class="value-icon">03</span>
            <div>
              <h3>Wspólna wartość</h3>
              <p>Efekty wzmacniają członków i kolejne inicjatywy.</p>
            </div>
          </article>
        </div>
        <div class="economy-principles">
          <span><b>✓</b> Dobrowolny udział</span>
          <span><b>✓</b> Jasne zasady</span>
          <span><b>✓</b> Współodpowiedzialność</span>
        </div>
      </div>
    </div>
  </section>

  <section class="container practice-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Wspólnota w praktyce</p>
        <h2>Co nas spaja na co dzień.</h2>
      </div>
      <p>
        Konkretne zasady, na których opieramy wspólne działanie — od rozwoju,
        przez składkę, po to, kim jesteśmy.
      </p>
    </div>
    <div class="practice-grid">
      <article class="practice-card">
        <span class="practice-tag">Rozwój i współpraca</span>
        <p>
          Budujemy dobrobyt: intelektualny, zdrowotny i finansowy.
          Wspieramy biznesy członków. Tworzymy wspólne przedsięwzięcia
          i lokalne grupy.
        </p>
      </article>
      <article class="practice-card">
        <span class="practice-tag">Składka</span>
        <p>
          Członkowie grupy zrzucają się po 12 zł rocznie.
          O przeznaczeniu składki decydujemy wspólnie, w głosowaniach.
        </p>
      </article>
      <article class="practice-card">
        <span class="practice-tag">Dlaczego „Lobby Obywatelskie”</span>
        <p>
          Nasza grupa nazywa się Lobby Obywatelskie, ponieważ działamy
          z pozycji obywateli i na rzecz obywateli. Działamy oddolnie
          i zachowujemy neutralność polityczną.
        </p>
      </article>
    </div>
  </section>

  <section class="manifest-band">
    <div class="container manifest-grid">
      <div class="manifest-mark" aria-hidden="true">
        <span>1</span>
        <div><b>OSOBA</b><i></i><b>GŁOS</b></div>
        <span>1</span>
      </div>
      <div class="manifest-copy">
        <p class="eyebrow">Nasze zobowiązanie</p>
        <h2>Nie czekamy, aż ktoś zmieni świat za nas.</h2>
        <p>
          Jesteśmy neutralnym politycznie, oddolnym ruchem społecznym.
          Łączą nas wolność, odpowiedzialność i przekonanie, że sprawy wspólne
          powinny być rozstrzygane wspólnie.
        </p>
        <a class="text-link" href={url('/manifest')}>Przeczytaj manifest <span>→</span></a>
      </div>
    </div>
  </section>

  <section class="container news-section">
    <div class="news-head">
      <div>
        <p class="eyebrow">Aktualności</p>
        <h2>Jesteśmy w ruchu.</h2>
      </div>
      <a class="news-all" href={url('/aktualnosci')}>Wszystkie aktualności <span>→</span></a>
    </div>
    <div class="news-grid">
      {posts.map((p) => (
        <NewsCard title={p.data.title} date={p.data.date} description={p.data.description} href={url(`/aktualnosci/${p.slug}`)} />
      ))}
    </div>
  </section>

  <section class="container join">
    <div>
      <p class="eyebrow">Spotkajmy się</p>
      <h2>Masz pomysł? Zacznijmy od rozmowy.</h2>
      <p>Spotykamy się online w każdą środę o 21:00. Wejście otwarte dla każdego.</p>
    </div>
    <div class="join-actions">
      <a class="btn" href="https://rozmowy.wikikracja.pl/otwarte" target="_blank" rel="noopener noreferrer">Dołącz do spotkania</a>
      <a class="btn btn--ghost" href={url('/kontakt')}>Napisz do nas</a>
    </div>
  </section>

  <style>
    .section-heading {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(18rem, .8fr);
      gap: 3rem;
      align-items: end;
      margin-bottom: 2.5rem;
    }
    .section-heading h2, .news-head h2, .manifest-copy h2, .join h2 {
      font-size: var(--step-3);
      margin: 0;
    }
    .section-heading > p { max-width: 31rem; margin: 0; color: var(--muted); }
    .how {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-auto-rows: 1fr;
      gap: 1.1rem;
      align-items: stretch;
    }
    .how-item {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 1.6rem;
      border: 1px solid var(--line);
      border-radius: .9rem;
      background: rgba(255,255,255,.75);
      box-shadow: 0 10px 35px rgba(13,33,59,.045);
      transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }
    .how-item:hover { transform: translateY(-5px); border-color: #c7d5e3; box-shadow: var(--shadow-sm); }
    .how-top { display: flex; align-items: center; justify-content: space-between; }
    .how-icon {
      display: grid;
      place-items: center;
      width: 3.25rem;
      height: 3.25rem;
      border-radius: .8rem;
      background: var(--blue-light);
      color: var(--blue);
      font: 700 1.3rem var(--f-display);
    }
    .how-item:nth-child(2) .how-icon { background: #fce8ec; color: var(--red); }
    .how-number { font: 700 1.7rem var(--f-display); color: #dde5ec; }
    .how-item h3 { font-size: var(--step-2); margin: 3rem 0 .8rem; }
    .how-item p { margin: 0; color: var(--muted); }

    .economy-section {
      padding: clamp(4.5rem, 9vw, 8rem) 0;
      background: #fff;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .economy-grid {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(31rem, 1.1fr);
      gap: clamp(3rem, 7vw, 6rem);
      align-items: center;
    }
    .economy-copy h2 { max-width: 14ch; margin: 0; font-size: var(--step-3); }
    .economy-copy > p:not(.eyebrow) { max-width: 38rem; margin: 1.3rem 0 1.7rem; color: var(--muted); }
    .economy-link {
      display: inline-flex;
      align-items: center;
      gap: .65rem;
      font: 700 .78rem var(--f-display);
      letter-spacing: .04em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .economy-link span { color: var(--red); font-size: 1.2rem; transition: transform .18s ease; }
    .economy-link:hover span { transform: translateX(4px); }
    .economy-panel {
      border: 1px solid #aebfce;
      border-radius: 1rem;
      background:
        linear-gradient(rgba(21,59,104,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(21,59,104,.035) 1px, transparent 1px),
        var(--paper);
      background-size: 24px 24px;
      box-shadow: var(--shadow-lg);
      overflow: hidden;
    }
    .economy-panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: .9rem 1.2rem;
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,.82);
      font: 700 .65rem var(--f-display);
      letter-spacing: .07em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .economy-panel-head strong { color: var(--blue); }
    .value-flow { display: grid; gap: .7rem; padding: 1.3rem; }
    .value-flow article {
      display: grid;
      grid-template-columns: 2.7rem 1fr;
      gap: .9rem;
      align-items: center;
      padding: 1rem;
      border: 1px solid var(--line);
      border-radius: .7rem;
      background: rgba(255,255,255,.94);
    }
    .value-icon {
      display: grid;
      place-items: center;
      width: 2.7rem;
      height: 2.7rem;
      border-radius: .6rem;
      background: var(--blue-light);
      color: var(--blue);
      font: 700 .68rem var(--f-display);
    }
    .value-flow article:nth-of-type(2) .value-icon { background: #f7e5e8; color: var(--red); }
    .value-flow article:nth-of-type(3) .value-icon { background: var(--blue); color: #fff; }
    .value-flow h3 { margin: 0 0 .2rem; font-size: 1rem; letter-spacing: -.01em; }
    .value-flow p { margin: 0; color: var(--muted); font-size: .78rem; }
    .value-flow > i { height: .55rem; color: var(--red); font: 700 .8rem var(--f-display); text-align: center; transform: rotate(90deg); }
    .economy-principles {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--line);
      background: #fff;
    }
    .economy-principles span {
      padding: .9rem .6rem;
      border-right: 1px solid var(--line);
      font: 700 .62rem var(--f-display);
      text-align: center;
      text-transform: uppercase;
      letter-spacing: .04em;
      color: var(--muted);
    }
    .economy-principles span:last-child { border-right: 0; }
    .economy-principles b { color: #167252; margin-right: .25rem; }

    .practice-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-auto-rows: 1fr;
      gap: 1.1rem;
    }
    .practice-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      height: 100%;
      padding: 1.7rem;
      border: 1px solid var(--line);
      border-radius: .9rem;
      background: rgba(255,255,255,.75);
      box-shadow: 0 10px 35px rgba(13,33,59,.045);
    }
    .practice-card p { margin: 0; color: var(--muted); }
    .practice-tag {
      align-self: flex-start;
      padding: .42rem .72rem;
      border-radius: .5rem;
      background: var(--blue-light);
      color: var(--blue);
      font: 700 .66rem var(--f-display);
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .practice-card:nth-child(2) .practice-tag { background: #fce8ec; color: var(--red); }
    .practice-card:nth-child(3) .practice-tag { background: var(--blue); color: #fff; }

    .manifest-band {
      padding: clamp(4rem, 8vw, 7rem) 0;
      background: var(--blue);
      color: #fff;
      overflow: hidden;
    }
    .manifest-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(3rem, 8vw, 7rem); align-items: center; }
    .manifest-mark {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      min-height: 18rem;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,.09), transparent 65%);
      font: 700 clamp(4rem, 10vw, 8rem)/1 var(--f-display);
    }
    .manifest-mark > span:last-child { color: var(--red); }
    .manifest-mark div { display: grid; justify-items: center; gap: .6rem; font-size: .68rem; letter-spacing: .14em; }
    .manifest-mark i { width: 2.8rem; height: 3px; background: var(--red); transform: rotate(-12deg); }
    .manifest-copy .eyebrow { color: #fff; }
    .manifest-copy .eyebrow::before { background: var(--red); }
    .manifest-copy h2 { color: #fff; max-width: 13ch; }
    .manifest-copy > p:not(.eyebrow) { max-width: 35rem; color: #d9e3ed; margin: 1.3rem 0 1.8rem; }
    .text-link, .news-all {
      display: inline-flex;
      align-items: center;
      gap: .65rem;
      font: 700 .82rem var(--f-display);
      letter-spacing: .04em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .text-link { color: #fff; }
    .text-link span, .news-all span { color: var(--red); font-size: 1.2rem; transition: transform .18s ease; }
    .text-link:hover span, .news-all:hover span { transform: translateX(4px); }

    .news-head { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-bottom: 2.5rem; }
    .news-all { padding-bottom: .35rem; color: var(--blue); }
    .news-grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); }

    .join {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .join h2 { max-width: 16ch; font-size: var(--step-2); }
    .join-actions { display: flex; flex-wrap: wrap; gap: .85rem; flex: 0 0 auto; }
    .join p:last-child { margin: .75rem 0 0; color: var(--muted); }

    @media (max-width: 760px) {
      .section-heading, .economy-grid, .practice-grid, .manifest-grid { grid-template-columns: 1fr; }
      .section-heading { gap: 1.25rem; }
      .how { grid-template-columns: 1fr; }
      .how-item h3 { margin-top: 2rem; }
      .economy-grid { gap: 2.5rem; }
      .manifest-mark { min-height: 14rem; max-width: 24rem; width: 100%; justify-self: center; }
      .news-head, .join { align-items: flex-start; flex-direction: column; }
    }
    @media (max-width: 480px) {
      .economy-principles { grid-template-columns: 1fr; }
      .economy-principles span { border-right: 0; border-bottom: 1px solid var(--line); }
      .economy-principles span:last-child { border-bottom: 0; }
    }
  </style>
</BaseLayout>
