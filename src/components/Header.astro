---
const links = [
  { href: '/', label: 'Start' },
  { href: '/manifest', label: 'Manifest' },
  { href: '/aktualnosci', label: 'Aktualności' },
  { href: '/kontakt', label: 'Kontakt' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Lobby Obywatelskie — strona główna">
      <img src="/img/logo.png" alt="Lobby Obywatelskie" width="1189" height="343" />
    </a>
    <button class="nav-toggle" aria-label="Otwórz menu" aria-expanded="false" aria-controls="main-nav">Menu</button>
    <nav id="main-nav" class="nav" aria-label="Główna nawigacja">
      {links.map((l) => (
        <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>
  </div>
</header>
<style>
  .site-header {
    background: var(--ink);
    border-bottom: 3px solid var(--red);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.5rem;
  }
  .logo { display: inline-flex; align-items: center; }
  .logo img { height: 2.1rem; width: auto; display: block; }
  .nav { display: flex; gap: 1.75rem; }
  .nav a {
    font-family: var(--f-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f3f1ea;
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }
  .nav a:hover { border-color: var(--red); }
  .nav a[aria-current="page"] { border-color: var(--red); color: #fff; }
  .nav-toggle {
    display: none;
    font-family: var(--f-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: none;
    border: 1px solid #4a4c52;
    border-radius: 2px;
    color: #f3f1ea;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
  }
  @media (max-width: 640px) {
    .nav-toggle { display: block; }
    .nav {
      display: none;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      padding-top: 1rem;
    }
    .nav.open { display: flex; }
    .header-inner { flex-wrap: wrap; }
  }
</style>
<script>
  const btn = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.nav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
    btn.setAttribute('aria-label', open ? 'Zamknij menu' : 'Otwórz menu');
  });
</script>
