---
import { url, asset } from '../lib/site';
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Demokracja zaczyna się od Ciebie</p>
      <h1>Razem możemy <span class="hl">więcej.</span></h1>
      <p class="lede">
        Oddajemy decyzje w ręce obywateli. Bez partyjnych podziałów,
        bez pustych obietnic — z równym głosem dla każdego.
      </p>
      <div class="hero-actions">
        <a class="btn" href={url('/kontakt')} rel="noopener noreferrer">Dołącz do nas</a>
        <a class="btn btn--ghost" href={url('/manifest')}>Poznaj nasz manifest</a>
      </div>
      <div class="hero-proof" aria-label="Najważniejsze zasady">
        <span><b>1</b> osoba</span>
        <i aria-hidden="true"></i>
        <span><b>1</b> głos</span>
        <i aria-hidden="true"></i>
        <span><b>100%</b> oddolnie</span>
      </div>
    </div>

    <figure class="hero-figure">
      <img
        src={asset('/img/hero2.webp')}
        width="1448"
        height="1086"
        alt="Obywatele z biało-czerwonymi flagami trzymający transparenty: „Decydujmy wspólnie o tym, co wspólne”, „Bez partyjnych podziałów”, „Oddajemy decyzję w ręce obywateli”, „Równy głos dla każdego”, „Twój głos ma znaczenie”; w tle rysunkowa panorama polskich krajobrazów i zabytków."
        loading="eager"
        fetchpriority="high"
      />
    </figure>
  </div>
</section>
<style>
  .hero {
    margin: 0;
    padding: clamp(2.25rem, 5vw, 4rem) 0 clamp(2.5rem, 6vw, 4.5rem);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255, 255, 255, .75), rgba(234, 240, 245, .2));
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  h1 {
    max-width: 11ch;
    font-size: var(--step-4);
    line-height: .94;
    margin: 0 0 1.25rem;
  }
  .hl { color: var(--red); }
  .lede { font-size: var(--step-1); max-width: 34rem; margin: 0 0 2rem; color: #455465; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; }
  .hero-proof {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.3rem;
    font: 700 0.78rem var(--f-display);
    letter-spacing: .03em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .hero-proof b { color: var(--blue); font-size: 1.05rem; }
  .hero-proof i { width: 4px; height: 4px; border-radius: 50%; background: var(--red); }

  .hero-figure { margin: 0; }
  .hero-figure img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 1rem;
    mix-blend-mode: multiply;
  }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .hero-figure { order: -1; max-width: 34rem; margin-inline: auto; }
    h1 { max-width: none; }
  }
</style>
