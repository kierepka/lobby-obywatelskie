---
const year = new Date().getFullYear();
const social = [
  { href: 'https://www.youtube.com/@LobbyObywatelskie', label: 'YouTube' },
  { href: 'https://chat.whatsapp.com/B9u07JqguLc0AX1WZDD0xH', label: 'WhatsApp' },
];
const legal = [
  { href: '/manifest', label: 'Manifest' },
  { href: '/aktualnosci', label: 'Aktualności' },
  { href: '/kontakt', label: 'Kontakt' },
  { href: '/polityka-prywatnosci', label: 'Polityka prywatności' },
  { href: '/deklaracja-dostepnosci', label: 'Dostępność' },
];
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand-col">
      <img class="footer-logo" src="/img/logo.png" alt="Lobby Obywatelskie" width="1189" height="343" />
      <p class="footer-tag">Oddolny ruch dla ludzi, którzy chcą mieć realny wpływ na wspólne decyzje.</p>
      <a class="footer-mail" href="mailto:kontakt@lobbyobywatelskie.pl">kontakt@lobbyobywatelskie.pl</a>
    </div>

    <nav class="footer-nav" aria-label="Stopka">
      <p class="footer-h">Strona</p>
      <ul>
        {legal.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Społeczności">
      <p class="footer-h">Znajdź nas</p>
      <ul>
        {social.map((s) => (
          <li><a href={s.href} target="_blank" rel="noopener noreferrer">{s.label} ↗</a></li>
        ))}
      </ul>
      <p class="meet"><b>Spotkania online</b><span>Środy, godz. 21:00</span></p>
    </nav>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} Lobby Obywatelskie</p>
    <p>Jedna osoba. Jeden głos.</p>
  </div>
</footer>
<style>
  .site-footer {
    background: #0c2039;
    color: #fff;
    padding: 4.5rem 0 2rem;
    margin-top: clamp(4rem, 9vw, 7rem);
    border-top: 5px solid var(--red);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr .8fr .8fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .footer-logo { height: 2.7rem; width: auto; display: block; margin-bottom: 1.25rem; filter: brightness(0) invert(1); }
  .footer-tag { color: #aebccc; margin: 0 0 1rem; max-width: 25rem; }
  .footer-mail { color: #fff; font: 700 .82rem var(--f-display); text-decoration-color: var(--red); }
  .footer-h {
    font: 700 .7rem var(--f-display);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #92a6bb;
    margin: 0 0 1rem;
  }
  .footer-nav ul { list-style: none; padding: 0; margin: 0; line-height: 2.1; }
  .site-footer a { color: #e6edf4; text-decoration: none; }
  .footer-nav a:hover { color: #fff; text-decoration: underline; text-decoration-color: var(--red); }
  .meet { display: grid; gap: .2rem; margin-top: 1.6rem; font-size: .85rem; }
  .meet span { color: #8fa1b4; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #253a52;
    font: 700 .68rem var(--f-display);
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #92a6bb;
  }
  .footer-bottom p { margin: 0; }
  @media (max-width: 700px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand-col { grid-column: 1 / -1; }
  }
</style>
